rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net catching all undefined paths
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Match validation helper
    function isValidMatch(data) {
      return data.id is string
        && data.id.size() <= 128
        && data.matchName is string
        && data.matchName.size() <= 200
        && data.teamAName is string
        && data.teamAName.size() <= 100
        && data.teamBName is string
        && data.teamBName.size() <= 100
        && data.overs is int
        && data.overs >= 1
        && data.overs <= 100
        && data.playersPerTeam is int
        && data.playersPerTeam >= 1
        && data.playersPerTeam <= 30
        && data.status is string
        && (data.status == 'created' || data.status == 'toss' || data.status == 'scoring' || data.status == 'completed')
        && (data.creatorId == null || data.creatorId is string);
    }

    // Strict Matches rules
    match /matches/{matchId} {
      // Any user (even unauthenticated) can read matches (both get and list)
      allow read: if true;

      // Anyone can create a valid match
      allow create: if isValidId(matchId) 
        && isValidMatch(incoming());

      // Anyone can update scoring or settings of a valid match
      allow update: if isValidId(matchId)
        && isValidMatch(incoming())
        && (
          // Protect finished matches: once status is completed, you cannot update unless correcting back
          existing().status != 'completed' || incoming().status == 'completed'
        );

      // Anyone can delete a match scorecard
      allow delete: if isValidId(matchId);
    }
  }
}
