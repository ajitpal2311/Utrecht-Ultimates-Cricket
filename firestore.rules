rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net catching all undefined paths
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Match validation helper
    function isValidMatch(data) {
      return data.get('id', '') is string
        && data.get('id', '').size() <= 128
        && data.get('matchName', '') is string
        && data.get('matchName', '').size() <= 200
        && data.get('teamAName', '') is string
        && data.get('teamAName', '').size() <= 100
        && data.get('teamBName', '') is string
        && data.get('teamBName', '').size() <= 100
        && data.get('overs', 1) is int
        && data.get('overs', 1) >= 1
        && data.get('overs', 1) <= 100
        && data.get('playersPerTeam', 11) is int
        && data.get('playersPerTeam', 11) >= 1
        && data.get('playersPerTeam', 11) <= 30
        && data.get('status', '') is string
        && (data.get('status', '') == 'created' || data.get('status', '') == 'toss' || data.get('status', '') == 'scoring' || data.get('status', '') == 'completed')
        && (data.get('creatorId', null) == null || data.get('creatorId', null) is string);
    }

    // Daily Attendance validation helper
    function isValidAttendance(data) {
      return data.get('id', '') is string
        && data.get('id', '').size() <= 40
        && data.get('players', []) is list
        && (data.get('teamA', null) == null || data.get('teamA', null) is list)
        && (data.get('teamB', null) == null || data.get('teamB', null) is list);
    }

    // Strict Matches rules
    match /matches/{matchId} {
      // Any user (even unauthenticated) can read matches (both get and list)
      allow read: if true;

      // Anyone can create a valid match
      allow create: if isValidId(matchId) 
        && isValidMatch(incoming());

      // Anyone can update scoring or settings of a valid match
      allow update: if isValidId(matchId)
        && isValidMatch(incoming())
        && (
          // Protect finished matches: once status is completed, you cannot update unless correcting back
          existing().get('status', '') != 'completed' || incoming().get('status', '') == 'completed'
        );

      // Anyone can delete a match scorecard
      allow delete: if isValidId(matchId);
    }

    // Attendance rules
    match /attendance/{dateId} {
      allow read: if true;
      allow write: if isValidId(dateId) && isValidAttendance(incoming());
    }

    // Viewer session rules (for active audience tracking)
    match /viewers/{viewerId} {
      allow read: if true;
      allow write: if isValidId(viewerId)
        && incoming().get('id', '') is string
        && incoming().get('id', '').size() <= 128
        && incoming().get('updatedAt', 0) is int;
    }
  }
}
